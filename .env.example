# Copy this file to .env for local development.
# Do not commit your real .env file.

OPENAI_API_KEY=replace-with-your-local-api-key
OPENAI_BASE_URL=http://127.0.0.1:3000/openai-codex-oauth/v1
CHAT_MODEL=gpt-5.4
EMBEDDING_MODEL=local-hash

VECTOR_DB_PATH=./data/index/chroma
RAW_EPUB_DIR=./data/raw/epub
BOOKS_JSONL_PATH=./data/processed/books_jsonl/books.jsonl
CHUNKS_JSONL_PATH=./data/processed/chunks_jsonl/chunks.jsonl
CHROMA_COLLECTION=reading_memory_chunks
